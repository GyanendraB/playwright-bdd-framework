{
  "name": "playwrightpractice",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "test": "cross-env ENV=qa cucumber-js",
    "test:single": "cross-env ENV=qa cucumber-js --parallel 0",
    "test:headed": "cross-env ENV=qa HEAD=true cucumber-js",
    "allure:generate": "allure generate ./allure-results --clean",
    "allure:open": "allure open ./allure-report",
    "clean": "rimraf reports",
    "report:cucumber": "node ./scripts/generate-cucumber-report.js",
    "test:reports": "cross-env ENV=qa cucumber-js && npm run report:cucumber && npm run allure:generate",
    "test:reports:single": "cross-env ENV=qa cucumber-js --parallel 0 && npm run report:cucumber && npm run allure:generate",
    "debug:cucumber": "node ./scripts/run-cucumber-debug.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "description": "",
  "repository": {
    "type": "git",
    "url": "https://github.com/GyanendraB/playwright-bdd-framework"
  },
  "devDependencies": {
    "@cucumber/cucumber": "^12.7.0",
    "@playwright/test": "^1.58.2",
    "allure-commandline": "^2.37.0",
    "allure-cucumberjs": "^3.5.0",
    "allure-playwright": "^3.5.0",
    "cross-env": "^10.1.0",
    "cucumber-html-reporter": "^7.2.0",
    "dotenv": "^17.3.1",
    "fs-extra": "^11.3.3",
    "rimraf": "^6.1.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
